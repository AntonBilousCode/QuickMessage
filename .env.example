APP_NAME=QuickMessage
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# Database
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=quickmessage
DB_USERNAME=quickmessage
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# -----------------------------------------------
# Cache & Session
# -----------------------------------------------
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# SECURITY: Must be true in production (HTTPS required).
# Prevents session cookie from being sent over plain HTTP connections.
SESSION_SECURE_COOKIE=false

# -----------------------------------------------
# Queue
# -----------------------------------------------
QUEUE_CONNECTION=redis

# -----------------------------------------------
# Redis
# -----------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# External ports (for local Docker port mapping)
DB_PORT_EXTERNAL=3306
REDIS_PORT_EXTERNAL=6379

# -----------------------------------------------
# Broadcasting (Laravel Reverb)
# -----------------------------------------------
BROADCAST_CONNECTION=reverb

# Reverb application credentials — CHANGE ALL THREE IN PRODUCTION!
REVERB_APP_ID=quickmessage-app
REVERB_APP_KEY=quickmessage-key-local
REVERB_APP_SECRET=quickmessage-secret-local

# CLIENT-FACING: where the browser connects (public hostname — never a Docker service name!)
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# SERVER-FACING (PHP → Reverb): Docker service name for PHP broadcasting dispatch.
# MUST be the Docker service name when running in containers.
# Set to 'localhost' only for local dev outside Docker.
REVERB_APP_HOST=reverb
REVERB_APP_PORT=8080

# SERVER-FACING: where Reverb daemon binds inside Docker
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# -----------------------------------------------
# Vite / Frontend (read by vite.config.js & JS)
# -----------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -----------------------------------------------
# Nginx
# -----------------------------------------------
NGINX_PORT=80

# -----------------------------------------------
# Production checklist
# -----------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# SESSION_SECURE_COOKIE=true       (requires HTTPS)
# REVERB_ALLOWED_ORIGINS=yourdomain.com  (restrict WebSocket origins)
# DB_PASSWORD=<strong-random-password>
# DB_ROOT_PASSWORD=<strong-random-password>
# REVERB_APP_KEY=<random-32-chars>
# REVERB_APP_SECRET=<random-64-chars>
